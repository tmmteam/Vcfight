# ── OPTIONAL ───────────────────────────────────

# Sudo users (comma-separated IDs)
SUDO_USERS=

# Log channel/group ID (negative for groups)
LOG_CHANNEL=

# MongoDB database name
DB_NAME=vcfighter

# ── VC Defaults (overridden by /config panel) ──
DEFAULT_MODE=dm
DEFAULT_STREAM_TYPE=audio
DEFAULT_QUALITY=medium
DEFAULT_NOISE_SUPPRESSION=false

# ── FFmpeg Defaults (overridden by /config panel) ──
DEFAULT_VOLUME=1.0
DEFAULT_BASS=0
DEFAULT_PITCH=normal
DEFAULT_ECHO=false
DEFAULT_COMPRESSOR=false
DEFAULT_LIMITER=false

# ── Recordings ─────────────────────────────────
RECORDINGS_DIR=recordings
MAX_RECORDING_AGE=3600

# ── Startup Userbots (fallback if DB empty) ────
# Comma-separated Pyrogram V2 string sessions
STARTUP_SESSIONS=

# ── Branding ───────────────────────────────────
BOT_NAME=VCFighter
BOT_VERSION=2.0
SUPPORT_URL=https://t.me/tmm_bots
SOURCE_URL=https://github.com/tmmteam/VCFIGHTER

